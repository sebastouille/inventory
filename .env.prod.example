INVENTORY_POSTGRES_USER=inventory
INVENTORY_POSTGRES_PASSWORD=replace-with-inventory-postgres-password
INVENTORY_POSTGRES_DB=inventory
INVENTORY_DATABASE_URL=postgresql://inventory:replace-with-inventory-postgres-password@db:5432/inventory

JWT_SECRET=replace-with-long-random-jwt-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret

NEXT_PUBLIC_API_URL=https://api.inventory.gestionai.fr/api/v1
API_BASE_URL=http://api:3011/api/v1
NEXT_PUBLIC_WEB_APP_URL=https://inventory.gestionai.fr
CORS_ALLOWED_ORIGINS=https://inventory.gestionai.fr,https://admin.inventory.gestionai.fr

INVENTORY_BOOTSTRAP_ENABLED=false
INVENTORY_BOOTSTRAP_ORGANIZATION_NAME=Inventory
INVENTORY_BOOTSTRAP_ORGANIZATION_SLUG=inventory
INVENTORY_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
INVENTORY_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-temporary-password
