{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "cross-env DATABASE_URL=postgresql://inventory:inventory@127.0.0.1:5560/inventory PRISMA_SCHEMA_PATH=../../prisma/schema.prisma ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:migrations": "vitest run test/prisma-migrations.spec.ts",
    "db:generate": "powershell -ExecutionPolicy Bypass -File ../../scripts/prisma-generate-safe.ps1 -SchemaPath prisma/schema.prisma -DatabaseUrl postgresql://inventory:inventory@127.0.0.1:5560/inventory",
    "db:migrate": "cross-env DATABASE_URL=postgresql://inventory:inventory@127.0.0.1:5560/inventory prisma migrate dev --name init_inventory --schema ../../prisma/schema.prisma",
    "db:seed": "cross-env DATABASE_URL=postgresql://inventory:inventory@127.0.0.1:5560/inventory TS_NODE_PROJECT=../../tsconfig.seed.json ts-node ../../prisma/seed.ts",
    "db:backfill-spatial": "cross-env DATABASE_URL=postgresql://inventory:inventory@127.0.0.1:5560/inventory TS_NODE_PROJECT=../../tsconfig.seed.json ts-node ../../prisma/backfill-spatial.ts",
    "db:backfill-equipment-spatial": "cross-env DATABASE_URL=postgresql://inventory:inventory@127.0.0.1:5560/inventory TS_NODE_PROJECT=../../tsconfig.seed.json ts-node ../../prisma/backfill-equipment-spatial.ts",
    "db:reset-test-imports-spatial": "cross-env DATABASE_URL=postgresql://inventory:inventory@127.0.0.1:5560/inventory TS_NODE_PROJECT=../../tsconfig.seed.json ts-node ../../prisma/reset-test-imports-spatial.ts"
  },
  "dependencies": {
    "@inventory/shared": "*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "^4.0.8",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.5",
    "prisma": "^6.8.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.8"
  }
}
